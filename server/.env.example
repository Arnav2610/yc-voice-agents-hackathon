# yc-voice-agent-hackathon / Chronos 911 - Environment Variables
# Copy this file to ../.env (repo root) and fill in your API keys.

# Twilio (Transport — optional; local WebRTC is the supported demo path)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Gradium (TTS, and optional STT fallback)
GRADIUM_API_KEY=
GRADIUM_VOICE_ID=

# OpenAI (optional — Chronos uses Nemotron; no OpenAI key required)
OPENAI_API_KEY=

# NVIDIA Nemotron ASR (STT) — provided during the hackathon
NVIDIA_ASR_URL=ws://44.241.251.184:8080

# NVIDIA Nemotron LLM — provided during the hackathon
NEMOTRON_LLM_URL=http://nemotron-fleet-alb-1322439314.us-west-2.elb.amazonaws.com/v1
NEMOTRON_LLM_MODEL=nvidia/nemotron-3-super
NEMOTRON_ENABLE_THINKING=false

# Supermemory (institutional memory). Without a key Chronos uses a local store.
SUPERMEMORY_API_KEY=

# Cekura (optional REST key; live runs are typically driven via the Cekura MCP)
CEKURA_API_KEY=

# --- Chronos 911 settings ---
CHRONOS_MODE=demo
CHRONOS_USE_SUPERMEMORY=true
CHRONOS_REQUIRE_HUMAN_ESCALATION=true
CHRONOS_DASHBOARD_PORT=7861
CHRONOS_STT=nvidia
CHRONOS_VOICE_THINKING=false
